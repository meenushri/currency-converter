pipeline {
    agent any

    stages {
        stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/meenushri/currency-converter.git'
            }
        }

        stage('Build') {
            steps {
                bat 'javac CurrencyConverter.java'
            }
        }

        stage('Test') {
            steps {
                bat 'javac -cp ".;junit-4.13.2.jar" CurrencyConverterTest.java'
                bat 'java -cp ".;junit-4.13.2.jar;hamcrest-core-1.3.jar" org.junit.runner.JUnitCore CurrencyConverterTest'
            }
        }

        stage('Deploy') {
            steps {
                bat 'java CurrencyConverter'
            }
        }
    }

    post {
        success {
            echo 'All Tests Passed!'
        }
        failure {
            echo 'Build Failed!'
        }
    }
}